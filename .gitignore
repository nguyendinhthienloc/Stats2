# ==========================
# R artifacts
# ==========================
.Rhistory
.Rdata
.RData
*.RData
.Rproj.user/
Rplots.pdf

# ==========================
# Generated output (reproducible)
# ==========================
output/figures/*.pdf
output/figures/*.png
output/tables/*.tex
output/*.RData

# ==========================
# LaTeX build artifacts
# ==========================
report/*.aux
report/*.bbl
report/*.bcf
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.toc
report/*.lof
report/*.lot
report/*.synctex.gz
report/*.run.xml
report/*.nav
report/*.snm
report/*.vrb
report/sections/*.aux
report/appendices/*.aux

# Keep the output directories
!output/figures/.gitkeep
!output/tables/.gitkeep
