.Rhistory
.Rdata
.RData
*.RData
.Rproj.user/
Rplots.pdf
.Rlib/

# ==========================
# Generated output (reproducible)
# ==========================
output/figures/*.pdf
output/figures/*.png
output/tables/*.tex
output/*.RData

