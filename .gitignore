LaTeX_report/*.run.xml
LaTeX_report/*.nav
LaTeX_report/*.snm
LaTeX_report/*.vrb
LaTeX_LaTeX_report/sections/*.aux
LaTeX_LaTeX_report/appendices/*.aux

# Keep the output directories
!output/figures/.gitkeep
!output/tables/.gitkeep
